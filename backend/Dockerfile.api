# Dockerfile.api
FROM node:22-alpine

WORKDIR /app

# Install dependencies first for layer caching
COPY package*.json ./
RUN npm ci --only=production

# Copy application source
COPY src ./src
# Ensure utils and infrastructure folders are included (src/ covers this)

# Expose API port
EXPOSE 5001

# Run the API server
CMD ["node", "src/server.js"]
